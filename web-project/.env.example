# SmartFarm web — API host (origin only, no /api path)
# The app appends /api/... per request (see public/js/api-origin.js, api-config.js).
# Wrong: https://example.up.railway.app/api  → can produce https://.../api/api/... in some code paths.
# Right:
VITE_API_URL=https://web-production-86d39.up.railway.app
# Optional alias (same value as VITE_API_URL; Netlify may set either)
# VITE_API_BASE_URL=https://web-production-86d39.up.railway.app

VITE_APP_NAME=SmartFarm
VITE_APP_VERSION=1.0.0

# Optional monitoring
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=smartfarm-web@1.0.0
