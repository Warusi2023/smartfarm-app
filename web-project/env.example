# Environment Variables for SmartFarm Web
# Copy this file to .env.local for local development
# Set these variables in your deployment platform (Railway, Netlify, etc.)

# Backend origin only — client code appends /api/...
VITE_API_URL=https://web-production-86d39.up.railway.app

# Build tag for tracking deployments
APP_BUILD_TAG=local

# For Railway deployment
# VITE_API_URL=https://your-railway-backend-url.railway.app

# For Netlify deployment  
# VITE_API_URL=https://your-backend-origin.example.com