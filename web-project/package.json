{
  "name": "smartfarm-web",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.17 <=22"
  },
  "scripts": {
    "prebuild": "node scripts/fix-svg-viewbox.mjs",
    "build": "vite build",
    "postbuild": "node scripts/fix-svg-viewbox.mjs",
    "dev": "vite --host --port 5173",
    "preview": "vite preview --strictPort --port 4173",
    "start": "npx --yes serve -s dist -l ${PORT:-4173}",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "esbuild": "0.21.5",
    "typescript": "5.6.3",
    "vite": "^5.4.20"
  },
  "dependencies": {
    "@sentry/react": "^7.91.0",
    "serve": "14.2.1"
  },
  "overrides": {
    "@esbuild/*": "0.21.5"
  },
  "packageManager": "npm@10"
}
