{
  "name": "smartfarm-backend",
  "version": "1.0.0",
  "description": "SmartFarm Production Backend API. Deploy: node server.js (not server-simple.cjs).",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "echo \"(backend) nothing to build\"",
    "migrate": "node scripts/run-migrations.js",
    "migrate:prod": "node scripts/run-migrations.js",
    "import:ipm": "node scripts/import-ipm-reference-data.js",
    "import:ipm-regulatory": "node scripts/import-ipm-regulatory-data.js",
    "health": "node -e \"const logger=require('./utils/logger');fetch('http://127.0.0.1:'+(process.env.PORT||3000)+'/api/health').then(r=>r.text()).then(d=>logger.info('Health check',{response:d})).catch(e=>logger.errorWithContext('Health check failed',{error:e}))\"",
    "setup:db": "node scripts/setup-database.js",
    "setup:env": "node scripts/create-env-file.js",
    "test:db": "node scripts/test-db-connection.js",
    "test:email": "node scripts/test-email-service.js",
    "test:email-verification": "node scripts/test-email-verification.js",
    "test": "cross-env NODE_ENV=test jest",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:unit": "cross-env NODE_ENV=test jest --testPathPattern=tests/unit",
    "test:w3": "cross-env NODE_ENV=test jest --testPathPattern=\"writeIdempotency|offlineWriteQueue\"",
    "test:w3:deployed": "node scripts/w3-deployed-smoke.js",
    "test:integration": "cross-env NODE_ENV=test jest --testPathPattern=tests/integration"
  },
  "engines": {
    "node": ">=18 <=22",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@sentry/node": "^7.91.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^7.0.10",
    "pg": "^8.11.3",
    "redis": "^4.6.0",
    "stripe": "^14.25.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "validator": "^13.11.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "smartfarm",
    "agriculture",
    "farming",
    "api"
  ],
  "author": "SmartFarm Team",
  "license": "MIT"
}
